[Unit]
Description=Vector Service
After=network.target
Wants=network.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/bin/vector --config-yaml /etc/vector/vector.yml
Restart=always
RestartSec=10
AmbientCapabilities=CAP_NET_BIND_SERVICE
Environment=VECTOR_REQUIRE_HEALTHY=false

# Security settings
NoNewPrivileges=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectSystem=full
ProtectHome=yes
ReadWritePaths=/var/lib/vector

[Install]
WantedBy=multi-user.target
